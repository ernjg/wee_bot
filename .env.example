# Wee
WEE_SLACK_BOT_TOKEN=xoxb-...
WEE_SLACK_APP_TOKEN=xapp-...

# Irdnennam
IRDNENNAM_SLACK_BOT_TOKEN=xoxb-...
IRDNENNAM_SLACK_APP_TOKEN=xapp-...

# Agent-specific Ollama models
WEE_OLLAMA_MODEL=qwen2.5:14b
WEE_TOOL_ROUTER_MODEL=qwen2.5:14b
IRDNENNAM_OLLAMA_MODEL=qwen2.5:14b
IRDNENNAM_TOOL_ROUTER_MODEL=qwen2.5:14b

# Voice notes
VOICE_ENABLED=0
TTS_PROVIDER=f5-tts
F5_TTS_MODEL=F5TTS_v1_Base
F5_TTS_PYTHON_EXE=.venv\Scripts\python.exe
F5_TTS_VOICE=example
F5_TTS_REF_AUDIO=assets\voices\example\reference.wav
F5_TTS_REF_TEXT=TODO: exact transcript of the reference audio.
F5_TTS_LANGUAGE=en-us
F5_TTS_SPEED=1.0
VOICE_FORMAT=wav
VOICE_MAX_CHARS=2400
VOICE_RESPONSE_CHANCE=0.04

# Slack/context behavior
THREAD_FETCH_LIMIT=40
CHANNEL_FETCH_LIMIT=30
MAX_THREAD_LINES=12
MAX_CHANNEL_LINES=6
MAX_MEMORY_LINES=8

# Ollama behavior
OLLAMA_NUM_PREDICT=120
OLLAMA_NUM_CTX=4096
OLLAMA_TEMPERATURE=0.7
OLLAMA_TIMEOUT_SECONDS=90

# Thread/memory behavior
ACTIVE_THREAD_TTL_SECONDS=14400
MAX_ACTIVE_THREADS=25
MAX_AUTO_REPLIES_PER_THREAD=6
MAX_MEMORIES=200
LOW_CONFIDENCE_MEMORY_TTL_DAYS=30
AMBIENT_RESPONSE_CHANCE=0.15
THREAD_AMBIENT_RESPONSE_CHANCE=0.35
REACTION_RESPONSE_CHANCE=0.65

# Debug
DEBUG=1
EVENT_LOG_ENABLED=0
EVENT_LOG_PATH=logs/events.jsonl
